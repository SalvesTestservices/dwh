<div class="max-w-4xl mx-auto mt-10">
  <h1 class="text-2xl font-semibold text-gray-900 mb-6">
    Create New Dataview
  </h1>

  <div class="bg-white shadow rounded-lg p-6" 
       data-controller="query-builder">
    <%= form_with url: dataview_index_path, 
                  data: { turbo: true },
                  class: "space-y-6" do |f| %>
      
      <%# Metric Selection Step %>
      <div class="step" data-query-builder-target="stepContainer">
        <div class="space-y-4">
          <%= f.label :metric, 
                      "What would you like to measure?",
                      class: "block text-sm font-medium text-gray-700" %>
          
          <%= f.select :metric,
                      @available_metrics.map { |k, v| [v, k] },
                      { prompt: "Select a metric" },
                      { 
                        class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm rounded-md",
                        data: {
                          action: "change->query-builder#metricSelected",
                          "query-builder-target" => "metricSelect"
                        }
                      } %>
        </div>

        <%# This is where the next step will be loaded %>
        <div id="nextStep" data-query-builder-target="nextStep"></div>
      </div>
    <% end %>
  </div>

  <div id="result" class="mt-8">
    <%# Results will be loaded here %>
  </div>
</div>